generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//AUTH
//Enums

enum Gender {
  male
  female
  other
}

enum Provider {
  EMAIL
  PHONE
  APPLE
  GOOGLE
}


enum Purpose {
  VERIFYPHONE
  VERIFYEMAIL
  LOGIN
  FORGOTPASSWORD
  UPDATEPASSWORD
  DELETEACCOUNT
}

//Models

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  passwordHash String?
  gender       Gender

  profileImage    String?

  isDeleted       Boolean       @default(false)
  isEmailVerified Boolean       @default(false)
  provider        Provider      @default(EMAIL)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  loggedDevices  LoggedDevices[]
  otp            Otp[]
  resumes        UserResume[]
  matchResults   MatchResult[]

  @@unique([email])
}


model LoggedDevices {
  id           Int      @id @default(autoincrement())
  userId       Int
  ipAddress    String?
  fcmToken     String?
  refreshToken String?
  deviceModel   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        Int      @id @default(autoincrement())
  userId    Int
  otp       String
  purpose   Purpose
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(255)
  description  String    @db.LongText
  embedding    Json      // 768-dimensional vector

  matches      MatchResult[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model UserResume {
  id           Int       @id @default(autoincrement())
  userId       Int
  fileName     String    @db.VarChar(255)
  originalText String    @db.LongText
  embedding    Json      // 768-dimensional vector

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches      MatchResult[]

  uploadedAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model MatchResult {
  id               Int     @id @default(autoincrement())
  userId           Int
  resumeId         Int
  jobId            Int
  similarityScore  Float
  explanation      String  @db.LongText

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           UserResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job              Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([resumeId])
  @@index([jobId])
}
