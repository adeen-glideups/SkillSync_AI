generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//AUTH
//Enums

enum Gender {
  male
  female
  other
}

enum Provider {
  EMAIL
  PHONE
  APPLE
  GOOGLE
}


enum Purpose {
  VERIFYPHONE
  VERIFYEMAIL
  LOGIN
  FORGOTPASSWORD
  UPDATEPASSWORD
  DELETEACCOUNT
}

//Models

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  passwordHash String?
  gender       Gender

  profileImage    String?

  isDeleted       Boolean       @default(false)
  isEmailVerified Boolean       @default(false)
  provider        Provider      @default(EMAIL)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  loggedDevices  LoggedDevices[]
  otp            Otp[]
  resumes        UserResume[]
  matchResults   MatchResult[]
  contactInfo    UserContactInfo?
  applications   JobApplication[]

  @@unique([email])
}


model LoggedDevices {
  id           Int      @id @default(autoincrement())
  userId       Int
  ipAddress    String?
  fcmToken     String?
  refreshToken String?
  deviceModel   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Otp {
  id        Int      @id @default(autoincrement())
  userId    Int
  otp       String
  purpose   Purpose
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id          Int      @id @default(autoincrement())
  
  // Core Identity
  title       String   @db.VarChar(255)
  company     String   @db.VarChar(255)
  
  // Content (what gets embedded)
  description String   @db.LongText
  tags        Json?    // ["React", "Node.js"] — stored as array
  
  // Location & Work Type  
  location    String?  @db.VarChar(255)
  remote      Boolean  @default(false)
  jobType     String?  @db.VarChar(100) // "full-time", "contract", "part-time"
  
  // Source Tracking (critical for multi-API seeding)
  sourceApi   String   @db.VarChar(100) // "arbeitnow", "himalayas", "manual"
  sourceUrl   String?  @db.Text         // original job URL
  externalId  String?  @db.VarChar(255) // slug/id from the source API
  
  // AI Layer
  embedding   Json?    // 768-dim vector
  embeddedAt  DateTime? // when embedding was generated
  category    String?  @db.VarChar(100) // e.g. "software engineering", "design"
  
  // Metadata
  postedAt    DateTime? // original posting date from API
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  matches            MatchResult[]
  screeningQuestions JobScreeningQuestion?
  applications       JobApplication[]

  // Prevent duplicate imports from same source
  @@unique([sourceApi, externalId])
  @@index([remote])
  @@index([location])
  @@index([sourceApi])
}

model UserResume {
  id           Int       @id @default(autoincrement())
  userId       Int
  fileName     String    @db.VarChar(255)
  originalText String    @db.LongText
  embedding    Json      // 768-dimensional vector

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches      MatchResult[]
  applications JobApplication[]

  uploadedAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model MatchResult {
  id               Int     @id @default(autoincrement())
  userId           Int
  resumeId         Int
  jobId            Int
  similarityScore  Float
  explanation      String  @db.LongText

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           UserResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job              Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([resumeId])
  @@index([jobId])
}

// ─── EASY APPLY ──────────────────────────────────────────────────────────────

model UserContactInfo {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  phone       String?  @db.VarChar(20)
  countryCode String?  @db.VarChar(10)
  city        String?  @db.VarChar(100)
  country     String?  @db.VarChar(100)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobScreeningQuestion {
  id          Int      @id @default(autoincrement())
  jobId       Int      @unique
  questions   Json     // [{ question: string, type: "text"|"yesno"|"number" }]
  generatedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id              Int      @id @default(autoincrement())
  userId          Int
  jobId           Int
  resumeId        Int
  contactSnapshot Json     // { email, phone, countryCode, city, country } at time of apply
  answers         Json     // [{ question: string, answer: string }]
  status          String   @default("APPLIED") @db.VarChar(50)
  appliedAt       DateTime @default(now())

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume UserResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}
