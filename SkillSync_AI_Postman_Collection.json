    {
      "name": "📄 Resume Management",
      "item": [
        {
          "name": "1. Upload Resume (PDF/DOCX)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('resume_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "resume",
                  "description": "Upload your resume PDF or DOCX file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/resumes/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "resumes",
                "upload"
              ]
            }
          }
        }
